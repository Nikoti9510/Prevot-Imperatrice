featurePrefixes = (
{
automatic = 1;
code = "languagesystem DFLT dflt;\012\012languagesystem latn dflt;\012languagesystem latn AZE;\012languagesystem latn CRT;\012languagesystem latn KAZ;\012languagesystem latn TAT;\012languagesystem latn TRK;\012languagesystem latn ROM;\012languagesystem latn MOL;\012languagesystem latn MAH;\012languagesystem latn PLK;\012languagesystem latn NLD;\012languagesystem latn CAT;\012";
name = Languagesystems;
}
);
features = (
{
automatic = 1;
code = "feature locl;\012feature ss01;\012feature ss02;\012feature ss03;\012";
name = aalt;
},
{
automatic = 1;
code = "lookup ccmp_DFLT_1 {\012	@CombiningTopAccents = [acutecomb brevecomb caroncomb circumflexcomb commaturnedabovecomb dieresiscomb dotaccentcomb gravecomb hungarumlautcomb macroncomb ringcomb tildecomb];\012	lookupflag UseMarkFilteringSet @CombiningTopAccents;\012	sub i' @CombiningTopAccents by idotless;\012	sub j' @CombiningTopAccents by jdotless;\012} ccmp_DFLT_1;\012";
name = ccmp;
},
{
automatic = 1;
code = "script latn;\012language AZE;\012lookup locl_latn_0 {\012	sub i by idotaccent;\012} locl_latn_0;\012language CRT;\012lookup locl_latn_0;\012language KAZ;\012lookup locl_latn_0;\012language TAT;\012lookup locl_latn_0;\012language TRK;\012lookup locl_latn_0;\012\012script latn;\012language ROM;\012lookup locl_latn_1 {\012	sub Scedilla by Scommaaccent;\012	sub scedilla by scommaaccent;\012	sub Tcedilla by Tcommaaccent;\012	sub tcedilla by tcommaaccent;\012} locl_latn_1;\012language MOL;\012lookup locl_latn_1;\012\012script latn;\012language MAH;\012lookup locl_latn_2 {\012	sub Lcommaaccent by Lcommaaccent.loclMAH;\012	sub Ncommaaccent by Ncommaaccent.loclMAH;\012	sub lcommaaccent by lcommaaccent.loclMAH;\012	sub ncommaaccent by ncommaaccent.loclMAH;\012	sub commaaccentcomb by commaaccentcomb.loclMAH;\012} locl_latn_2;\012\012script latn;\012language PLK;\012lookup locl_latn_3 {\012	sub Cacute by Cacute.loclPLK;\012	sub Nacute by Nacute.loclPLK;\012	sub Oacute by Oacute.loclPLK;\012	sub Sacute by Sacute.loclPLK;\012	sub Zacute by Zacute.loclPLK;\012	sub cacute by cacute.loclPLK;\012	sub nacute by nacute.loclPLK;\012	sub oacute by oacute.loclPLK;\012	sub sacute by sacute.loclPLK;\012	sub zacute by zacute.loclPLK;\012	sub acutecomb by acutecomb.loclPLK;\012} locl_latn_3;\012\012script latn;\012language NLD;\012lookup locl_latn_4 {\012	sub I J by I_J.loclNLD;\012	sub i j by i_j.loclNLD;\012	sub iacute j by iacute_j.loclNLD;\012	sub Iacute J by Iacute_J.loclNLD;\012} locl_latn_4;\012\012script latn;\012language CAT;\012lookup locl_latn_5 {\012	sub  l' periodcentered' l by ldot;\012	sub  L' periodcentered' L by Ldot;\012} locl_latn_5;\012";
name = locl;
},
{
automatic = 1;
code = "lookupflag IgnoreMarks;\012sub f f i by f_f_i.liga;\012sub F i by F_i.liga;\012sub F j by F_j.liga;\012sub T T by T_T.liga;\012sub T h by T_h.liga;\012sub T i by T_i.liga;\012sub V i by V_i.liga;\012sub W i by W_i.liga;\012sub f f by f_f.liga;\012sub f i by f_i.liga;\012";
name = liga;
},
{
automatic = 1;
code = "sub a by a.ss01;\012sub aacute by aacute.ss01;\012sub abreve by abreve.ss01;\012sub acircumflex by acircumflex.ss01;\012sub adieresis by adieresis.ss01;\012sub agrave by agrave.ss01;\012sub amacron by amacron.ss01;\012sub aogonek by aogonek.ss01;\012sub aring by aring.ss01;\012sub atilde by atilde.ss01;\012sub b by b.ss01;\012sub d by d.ss01;\012sub dcaron by dcaron.ss01;\012sub dcroat by dcroat.ss01;\012sub l by l.ss01;\012sub lacute by lacute.ss01;\012sub lcaron by lcaron.ss01;\012sub lcommaaccent by lcommaaccent.ss01;\012sub ldot by ldot.ss01;\012sub lslash by lslash.ss01;\012sub p by p.ss01;\012sub thorn by thorn.ss01;\012sub q by q.ss01;\012sub t by t.ss01;\012sub tbar by tbar.ss01;\012sub tcaron by tcaron.ss01;\012sub tcedilla by tcedilla.ss01;\012sub tcommaaccent by tcommaaccent.ss01;\012sub tdotbelow by tdotbelow.ss01;\012sub yal-tifi by yal-tifi.ss01;\012";
name = ss01;
notes = "Name: simple";
},
{
automatic = 1;
code = "sub a by a.ss02;\012sub aacute by aacute.ss02;\012sub abreve by abreve.ss02;\012sub acircumflex by acircumflex.ss02;\012sub adieresis by adieresis.ss02;\012sub agrave by agrave.ss02;\012sub amacron by amacron.ss02;\012sub aogonek by aogonek.ss02;\012sub aring by aring.ss02;\012sub atilde by atilde.ss02;\012sub g by g.ss02;\012sub gbreve by gbreve.ss02;\012sub gcommaaccent by gcommaaccent.ss02;\012sub gdotaccent by gdotaccent.ss02;\012";
